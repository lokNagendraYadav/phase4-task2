# Google Gemini API key — https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-gemini-key-here

# Tavily web search API key — https://app.tavily.com/  (free tier available)
TAVILY_API_KEY=your-tavily-key-here

# --- Optional model overrides ---
# Supervisor / orchestrator model (needs strong tool-calling / routing)
SUPERVISOR_MODEL=gemini-2.0-flash
# Worker sub-agent model (cheaper is fine)
WORKER_MODEL=gemini-2.0-flash
# LLM temperature
LLM_TEMPERATURE=0.1

# Directory holding internal documents for the summary agent
DOCS_DIR=docs
